# Aswathy Associates – GST & Auditing
# Environment Configuration

# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=aswathy_associates

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=aswathyandco@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Aswathy Associates <aswathyandco@gmail.com>"

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Admin Default Credentials (change after first login)
ADMIN_EMAIL=aswathyandco@gmail.com
ADMIN_PASSWORD=Admin@123456
